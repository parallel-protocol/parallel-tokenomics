{
  "name": "@parallel/tokenomics",
  "description": "Parallel Tokenomics",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "scripts": {
    "compile": "forge build && hardhat compile",
    "deploy": "hardhat deploy",
    "clean": "rm -rf cache out generated",
    "build": "forge build",
    "size": "forge build --sizes",
    "lint": "bun run lint:sol && bun run prettier:check",
    "lint:sol": "forge fmt --check && bun solhint \"{script,contracts,test}/**/*.sol\"",
    "prettier:check": "prettier --check \"**/*.{json,md,yml}\" --ignore-path \".prettierignore\"",
    "prettier:write": "prettier --write \"**/*.{json,md,yml}\" --ignore-path \".prettierignore\"",
    "test": "forge test -vvv --nmt \"^.*invariant.*$\"",
    "test:invariant": "forge test --mt \"^.*invariant.*$\"",
    "test:coverage": "forge coverage --ir-minimum",
    "test:coverage:report": "forge coverage --ir-minimum --report lcov && lcov --remove lcov.info -o lcov.info \"test/*\" && genhtml lcov.info -o coverage",
    "prepare": "husky",
    "verify": "rocketh-verify etherscan"
  },
  "dependencies": {
    "@layerzerolabs/lz-evm-oapp-v2": "^3.0.14",
    "@openzeppelin/contracts": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@layerzerolabs/lz-definitions": "^3.0.36",
    "@nomicfoundation/hardhat-viem": "^3.0.0",
    "@rocketh/deploy": "^0.19.8",
    "@rocketh/doc": "^0.19.7",
    "@rocketh/export": "^0.19.8",
    "@rocketh/proxy": "^0.19.14",
    "@rocketh/read-execute": "^0.19.3",
    "@rocketh/signer": "^0.19.3",
    "@rocketh/verifier": "^0.19.7",
    "@rocketh/viem": "^0.19.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.3.0",
    "dotenv": "^17.2.1",
    "forge-std": "github:foundry-rs/forge-std#v1.9.5",
    "fs-extra": "^11.3.0",
    "hardhat": "^3.0.3",
    "hardhat-deploy": "^2.0.0-next.40",
    "husky": "^9.1.6",
    "murky": "github:dmfxyz/murky",
    "prettier": "^3.5.3",
    "rocketh": "^0.19.7",
    "solhint": "^5.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "viem": "^2.37.1"
  }
}
